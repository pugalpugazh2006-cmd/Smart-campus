{
  "version": 2,
  "routes": [
    {
      "src": "/(.*)",
      "dest": "api/index.py"
    }
  ],
  "functions": {
    "api/index.py": {
      "maxDuration": 30,
      "excludeFiles": "{FINAL_DEPLOY/**,instance/**,__pycache__/**,*.zip,db.json,notifications.log,smart_campus_extracted/**,tests/**}"
    }
  }
}
